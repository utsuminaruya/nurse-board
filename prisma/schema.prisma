generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                  String   @id @default(cuid())
  name                String
  email               String   @unique
  password            String
  nurseQualifications String   @default("")
  preferredAreas      String   @default("")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  dispatchCompanies DispatchCompany[]
  jobs              Job[]
  monthlyGoals      MonthlyGoal[]
}

model DispatchCompany {
  id                   String   @id @default(cuid())
  userId               String
  companyName          String
  contactPerson        String   @default("")
  phone                String   @default("")
  email                String   @default("")
  lineId               String   @default("")
  communicationChannel String   @default("email")
  notes                String   @default("")
  color                String   @default("#3B82F6")
  createdAt            DateTime @default(now())

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobs Job[]

  @@index([userId])
}

model JobCategory {
  id                String  @id @default(cuid())
  name              String  @unique
  defaultHourlyRate Int     @default(0)
  icon              String  @default("briefcase")

  jobs Job[]
}

model Job {
  id                String   @id @default(cuid())
  userId            String
  dispatchCompanyId String
  jobCategoryId     String
  title             String
  description       String   @default("")
  facilityName      String   @default("")
  address           String   @default("")
  date              DateTime
  startTime         String   @default("")
  endTime           String   @default("")
  hourlyRate        Int      @default(0)
  transportationFee Int      @default(0)
  otherAllowances   Int      @default(0)
  status            String   @default("offered")
  priority          String   @default("medium")
  notes             String   @default("")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  dispatchCompany DispatchCompany @relation(fields: [dispatchCompanyId], references: [id], onDelete: Cascade)
  jobCategory     JobCategory     @relation(fields: [jobCategoryId], references: [id])

  @@index([userId])
  @@index([dispatchCompanyId])
  @@index([jobCategoryId])
  @@index([date])
  @@index([status])
}

model MonthlyGoal {
  id           String @id @default(cuid())
  userId       String
  year         Int
  month        Int
  targetIncome Int    @default(0)
  targetWorkDays Int  @default(0)
  notes        String @default("")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, year, month])
  @@index([userId])
}
